  "title": "DAGRunPatchBody",
  "description": "DAG Run Serializer for PATCH requests.",
  "type": "object",
  "properties": {
    "state": {
      "anyOf": [
        {
          "$ref": "#/components/schemas/DAGRunPatchStates"
        },
        {
          "type": "null"
        }
      ]
    },
    "note": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 1000
        },
        {
          "type": "null"
        }
      ],
      "title": "Note"
    }
  },
  "additionalProperties": false
}