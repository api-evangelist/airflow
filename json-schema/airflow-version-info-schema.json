{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/airflow/refs/heads/main/json-schema/airflow-version-info-schema.json",
  "title": "VersionInfo",
  "description": "Version information serializer for responses.",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "title": "Version"
    },
    "git_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Git Version"
    }
  },
  "required": [
    "version",
    "git_version"
  ]
}