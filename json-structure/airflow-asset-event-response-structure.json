{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/airflow/refs/heads/main/json-structure/airflow-asset-event-response-structure.json",
  "name": "AssetEventResponse",
  "description": "Asset event serializer for responses.",
  "type": "object",
  "properties": {
    "id": {
      "type": "int32",
      "title": "Id"
    },
    "asset_id": {
      "type": "int32",
      "title": "Asset Id"
    },
    "uri": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Uri"
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Name"
    },
    "group": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Group"
    },
    "extra": {
      "anyOf": [
        {
          "additionalProperties": {
            "$ref": "#/components/schemas/JsonValue"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "title": "Extra"
    },
    "source_task_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Source Task Id"
    },
    "source_dag_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Source Dag Id"
    },
    "source_run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Source Run Id"
    },
    "source_map_index": {
      "type": "int32",
      "title": "Source Map Index"
    },
    "created_dagruns": {
      "items": {
        "$ref": "#/components/schemas/DagRunAssetReference"
      },
      "type": "array",
      "title": "Created Dagruns"
    },
    "timestamp": {
      "type": "datetime",
      "title": "Timestamp"
    },
    "partition_key": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Partition Key"
    }
  },
  "required": [
    "id",
    "asset_id",
    "source_map_index",
    "created_dagruns",
    "timestamp"
  ]
}