{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/airflow/refs/heads/main/json-structure/airflow-connection-body-structure.json",
  "name": "ConnectionBody",
  "description": "Connection Serializer for requests body.",
  "type": "object",
  "properties": {
    "connection_id": {
      "type": "string",
      "maxLength": 200,
      "pattern": "^[\\w.-]+$",
      "title": "Connection Id"
    },
    "conn_type": {
      "type": "string",
      "title": "Conn Type"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Description"
    },
    "host": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Host"
    },
    "login": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Login"
    },
    "schema": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Schema"
    },
    "port": {
      "anyOf": [
        {
          "type": "int32"
        },
        {
          "type": "null"
        }
      ],
      "title": "Port"
    },
    "password": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Password"
    },
    "extra": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Extra"
    },
    "team_name": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 50
        },
        {
          "type": "null"
        }
      ],
      "title": "Team Name"
    }
  },
  "required": [
    "connection_id",
    "conn_type"
  ],
  "additionalProperties": false
}