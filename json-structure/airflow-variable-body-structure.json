{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/airflow/refs/heads/main/json-structure/airflow-variable-body-structure.json",
  "name": "VariableBody",
  "description": "Variable serializer for bodies.",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "maxLength": 250,
      "title": "Key"
    },
    "value": {
      "$ref": "#/components/schemas/JsonValue"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Description"
    },
    "team_name": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 50
        },
        {
          "type": "null"
        }
      ],
      "title": "Team Name"
    }
  },
  "required": [
    "key",
    "value"
  ],
  "additionalProperties": false
}