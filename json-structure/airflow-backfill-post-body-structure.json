{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/airflow/refs/heads/main/json-structure/airflow-backfill-post-body-structure.json",
  "name": "BackfillPostBody",
  "description": "Object used for create backfill request.",
  "type": "object",
  "properties": {
    "dag_id": {
      "type": "string",
      "title": "Dag Id"
    },
    "from_date": {
      "type": "datetime",
      "title": "From Date"
    },
    "to_date": {
      "type": "datetime",
      "title": "To Date"
    },
    "run_backwards": {
      "type": "boolean",
      "title": "Run Backwards",
      "default": false
    },
    "dag_run_conf": {
      "additionalProperties": true,
      "type": "object",
      "title": "Dag Run Conf",
      "default": {}
    },
    "reprocess_behavior": {
      "$ref": "#/components/schemas/ReprocessBehavior",
      "default": "none"
    },
    "max_active_runs": {
      "type": "int32",
      "title": "Max Active Runs",
      "default": 10
    },
    "run_on_latest_version": {
      "type": "boolean",
      "title": "Run On Latest Version",
      "default": true
    }
  },
  "required": [
    "dag_id",
    "from_date",
    "to_date"
  ],
  "additionalProperties": false
}